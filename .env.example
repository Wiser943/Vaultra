# ── VAULTRA Environment Variables ──────────────────────────
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub

# Server
PORT=3000
NODE_ENV=development

# MongoDB Atlas
# Get this from: https://cloud.mongodb.com → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@your-cluster.mongodb.net/vaultra?retryWrites=true&w=majority

# JWT Secret — use a long random string (min 32 chars)
# Generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=replace_this_with_a_long_random_secret_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# Korapay
# Get these from: https://merchant.korapay.com → Settings → API Keys
KORAPAY_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
KORAPAY_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
KORAPAY_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxx
KORAPAY_BASE_URL=https://api.korapay.com/merchant/api/v1

# App URL (your Render subdomain once deployed)
APP_URL=https://vaultra.onrender.com

# Admin secret (for manual account verification)
ADMIN_SECRET=replace_with_your_own_admin_password

# Plan prices in Kobo (Korapay uses kobo: ₦7000 = 700000 kobo)
STERLING_PRICE_KOBO=700000
SOVEREIGN_PRICE_KOBO=1500000
